---
import Layout from '../layouts/Layout.astro';
import HERO from '../assets/sun_on_desk.png';
import STARS from '../assets/stars.png';
import DINO from '../assets/green-dino.jpg';
import SUNMOON from '../assets/sun_and_moon.jpg';
import SUN_CLOSEUP from '../assets/sun_on_desk_closeup.png';
import SPIDEY from '../assets/spiderman.jpg';

const offerings = [
  { num: "01", name: "Sunshine Amigurumi", sub: "Best seller · 24 pieces", price: "from ₹ 649", tag: "Best seller", img: SUN_CLOSEUP.src, href: "#cta" },
  { num: "02", name: "Lil' Dino Keychain", sub: "New arrival · 18 pieces", price: "from ₹ 249", tag: "New", img: DINO.src, href: "#cta" },
  { num: "03", name: "Sun & Moon Pair", sub: "Set of 2 · 12 pieces", price: "from ₹ 449", tag: "Set of 2", img: SUNMOON.src, href: "#cta" },
  { num: "04", name: "Spidey Hanging", sub: "Limited run · 9 pieces", price: "from ₹ 549", tag: "Limited", img: SPIDEY.src, href: "#cta" },
  { num: "05", name: "Crochet Stars", sub: "Wall hangings · new", price: "from ₹ 399", tag: "New", img: STARS.src, href: "#cta" },
  { num: "06", name: "Custom Orders", sub: "By request · any idea", price: "Quote on inquiry", tag: "Custom", img: HERO.src, href: "#cta" },
];
---

<Layout title="Sunflora — Handmade Crochet, Made to Last" description="One-of-a-kind crochet pieces made slowly, sent with love. Amigurumi, keychains, florals & custom orders — straight from our hands to yours.">
  <style>
    /* ── Fonts already loaded by global.css ── */

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --amber:   #C8862C;
      --dark:    #1A1815;
      --light:   #EFE8DA;
      --grain:   #E5DFD1;
      --muted:   #4A453E;
      --border:  rgba(26,24,21,0.12);
    }

    body {
      background: var(--light);
      color: var(--dark);
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ─── UTILITIES ─────────────────────────────── */
    .serif   { font-family: 'Cormorant Garamond', serif; font-weight: 500; }
    .display { font-family: 'Cormorant Garamond', serif; font-weight: 500; letter-spacing: -0.03em; }
    .label   { font-size: 0.65rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--amber); }
    .container { max-width: 1400px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 5rem); }

    /* ─── NAV ────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem clamp(1.5rem, 5vw, 5rem);
      transition: all 0.4s;
    }
    nav.scrolled {
      background: rgba(239,232,218,0.88);
      backdrop-filter: blur(12px);
      padding-top: 1rem; padding-bottom: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-style: italic; color: var(--dark); text-decoration: none; }
    .nav-logo span { color: var(--amber); }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s; }
    .nav-links a:hover { color: var(--dark); }
    .nav-cta {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--dark); color: var(--light);
      padding: 0.65rem 1.4rem; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
      text-decoration: none; transition: background 0.4s;
    }
    .nav-cta:hover { background: var(--amber); }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
    }

    /* ─── HERO ───────────────────────────────────── */
    .hero {
      min-height: 100svh;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: stretch;
      border-bottom: 1px solid var(--border);
    }
    @media (max-width: 900px) { .hero { grid-template-columns: 1fr; } }

    .hero-left {
      padding: 10rem clamp(1.5rem, 5vw, 5rem) 5rem;
      display: flex; flex-direction: column; justify-content: center; gap: 2rem;
    }
    .hero-eyebrow { display: flex; align-items: center; gap: 1rem; }
    .hero-eyebrow::before { content: ''; display: block; width: 2.5rem; height: 1px; background: var(--amber); }
    .hero-h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-style: italic;
      font-size: clamp(3.5rem, 8vw, 7rem);
      line-height: 0.92; letter-spacing: -0.03em;
      color: var(--dark);
    }
    .hero-h1 strong { font-style: normal; color: var(--amber); }
    .hero-sub {
      font-size: clamp(0.9rem, 1.5vw, 1.05rem);
      line-height: 1.75; color: var(--muted); max-width: 34ch;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.6rem;
      background: var(--dark); color: var(--light);
      padding: 1rem 2rem; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
      text-decoration: none; transition: background 0.4s; border: none; cursor: pointer;
    }
    .btn-primary:hover { background: var(--amber); }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 0.5rem;
      color: var(--dark); font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
      text-decoration: none; border-bottom: 1px solid var(--dark); padding-bottom: 2px;
      transition: color 0.3s, border-color 0.3s;
    }
    .btn-ghost:hover { color: var(--amber); border-color: var(--amber); }

    .hero-stats {
      display: flex; gap: 2.5rem; padding-top: 2rem;
      border-top: 1px solid var(--border); margin-top: 1rem;
    }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; color: var(--dark); display: block; line-height: 1; }
    .stat-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-top: 0.3rem; }

    .hero-right {
      position: relative; overflow: hidden; background: var(--grain);
      min-height: 60svh;
    }
    @media (max-width: 900px) { .hero-right { min-height: 60vw; } }
    .hero-right img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 8s ease-out;
    }
    .hero-right:hover img { transform: scale(1.04); }
    .hero-badge {
      position: absolute; bottom: 2rem; left: 2rem;
      background: var(--light); border: 1px solid var(--border);
      padding: 1rem 1.4rem; max-width: 240px;
    }
    .hero-badge p { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.05rem; color: var(--dark); line-height: 1.4; }
    .hero-badge small { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-top: 0.4rem; display: block; }

    /* ─── TRUST BAR ──────────────────────────────── */
    .trust-bar {
      background: var(--dark); color: var(--light);
      display: flex; align-items: center; justify-content: center;
      gap: clamp(2rem, 5vw, 5rem); padding: 1.4rem 2rem;
      flex-wrap: wrap;
    }
    .trust-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.8; }
    .trust-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--amber); }

    /* ─── MARQUEE ────────────────────────────────── */
    .marquee-wrap {
      overflow: hidden; border-bottom: 1px solid var(--border);
      background: var(--grain); padding: 1.4rem 0;
    }
    .marquee-inner { display: flex; gap: 3rem; width: max-content; animation: marquee 30s linear infinite; }
    .marquee-inner span {
      font-family: 'Cormorant Garamond', serif; font-style: italic;
      font-size: clamp(1.5rem, 3vw, 2.2rem); color: var(--dark); white-space: nowrap;
      display: flex; align-items: center; gap: 3rem;
    }
    .marquee-inner span::after { content: '·'; color: var(--amber); }
    @keyframes marquee { to { transform: translateX(-50%); } }

    /* ─── SOCIAL PROOF / VIDEO SECTION (MasterClass-style) ─── */
    .proof-section {
      border-bottom: 1px solid var(--border);
      overflow: hidden;
    }
    .proof-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 560px;
    }
    @media (max-width: 900px) {
      .proof-grid { grid-template-columns: 1fr; min-height: auto; }
    }

    .proof-visual {
      position: relative;
      background: var(--dark);
      overflow: hidden;
      /* no aspect-ratio — let height be driven by sibling */
    }
    .proof-visual img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; opacity: 0.7; display: block;
    }
    @media (max-width: 900px) {
      .proof-visual { aspect-ratio: 4/3; }
      .proof-visual img { position: absolute; }
    }
    .proof-play {
      position: absolute; inset: 0; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 1.2rem; color: var(--light);
      text-align: center; z-index: 1;
    }
    .play-btn {
      width: 72px; height: 72px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.3s; background: rgba(255,255,255,0.1);
      backdrop-filter: blur(4px);
    }
    .play-btn:hover { background: var(--amber); border-color: var(--amber); transform: scale(1.08); }
    .play-btn svg { margin-left: 4px; }
    .proof-play h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-style: italic; max-width: 22ch; line-height: 1.3; }

    .proof-content {
      padding: clamp(3rem, 5vw, 5rem);
      display: flex; flex-direction: column; justify-content: center; gap: 2rem;
      background: var(--light);
      border-left: 1px solid var(--border);
      box-sizing: border-box;
    }
    @media (max-width: 900px) { .proof-content { border-left: none; border-top: 1px solid var(--border); } }

    .proof-content h2 {
      font-family: 'Cormorant Garamond', serif; font-weight: 500;
      font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.05; letter-spacing: -0.02em;
    }
    .proof-content h2 em { color: var(--amber); }
    .proof-content p { font-size: 1rem; line-height: 1.75; color: var(--muted); max-width: 38ch; }

    .proof-ticks { display: flex; flex-direction: column; gap: 0.8rem; }
    .proof-tick {
      display: flex; align-items: flex-start; gap: 0.8rem;
      font-size: 0.85rem; line-height: 1.5; color: var(--muted);
    }
    .tick-icon { color: var(--amber); margin-top: 2px; flex-shrink: 0; }

    /* ─── OFFERINGS GRID (photo product cards) ── */
    .offerings {
      padding: clamp(4rem, 8vw, 8rem) 0;
      border-bottom: 1px solid var(--border);
    }
    .offerings-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; margin-bottom: 3.5rem; flex-wrap: wrap; }
    .offerings-head h2 {
      font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 6vw, 5rem);
      letter-spacing: -0.03em; line-height: 1; font-weight: 500;
    }

    .offerings-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media (max-width: 900px) { .offerings-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 500px)  { .offerings-grid { grid-template-columns: 1fr; } }

    .offering-card {
      background: var(--grain);
      display: flex; flex-direction: column;
      cursor: pointer; overflow: hidden;
      text-decoration: none; color: inherit;
      border: 1px solid var(--border);
      transition: box-shadow 0.4s, transform 0.4s;
    }
    .offering-card:hover { box-shadow: 0 16px 48px rgba(26,24,21,0.13); transform: translateY(-3px); }
    .offering-card:hover .offering-img { transform: scale(1.05); }
    .offering-card:hover .offering-arrow { transform: rotate(45deg); }

    .offering-img-wrap {
      overflow: hidden; aspect-ratio: 4/3; background: var(--grain);
      position: relative;
    }
    .offering-img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
      display: block;
    }
    .offering-tag {
      position: absolute; top: 1rem; left: 1rem;
      background: var(--light); color: var(--dark);
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      padding: 0.25rem 0.7rem; border: 1px solid var(--border);
    }
    .offering-body {
      padding: 1.4rem 1.6rem 1.6rem;
      display: flex; flex-direction: column; gap: 0.4rem; flex: 1;
    }
    .offering-num { font-family: 'Cormorant Garamond', serif; font-size: 0.75rem; color: var(--amber); }
    .offering-name { font-family: 'Cormorant Garamond', serif; font-size: 1.7rem; line-height: 1.1; letter-spacing: -0.02em; }
    .offering-sub { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.2rem; }
    .offering-footer {
      display: flex; align-items: center; justify-content: space-between;
      margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border);
    }
    .offering-price { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--amber); }
    .offering-arrow { display: inline-block; transition: transform 0.4s; color: var(--amber); }

    /* ─── TESTIMONIALS (MasterClass quote wall) ─── */
    .testimonials {
      padding: clamp(4rem, 8vw, 8rem) 0;
      background: var(--dark); color: var(--light);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .testimonials-label { color: var(--amber); margin-bottom: 3rem; }
    .testi-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 2px; background: rgba(255,255,255,0.06);
    }
    @media (max-width: 700px) { .testi-grid { grid-template-columns: 1fr; } }

    .testi-card {
      padding: 2.5rem;
      background: var(--dark);
      display: flex; flex-direction: column; gap: 1.5rem;
    }
    .testi-quote {
      font-family: 'Cormorant Garamond', serif; font-style: italic;
      font-size: clamp(1.3rem, 2vw, 1.7rem); line-height: 1.45;
      color: var(--light);
    }
    .testi-stars { display: flex; gap: 0.25rem; color: var(--amber); }
    .testi-author { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(239,232,218,0.5); margin-top: auto; }

    /* ─── HOW IT WORKS ───────────────────────────── */
    .how {
      padding: clamp(4rem, 8vw, 8rem) 0;
      border-bottom: 1px solid var(--border);
    }
    .how-head { text-align: center; margin-bottom: 4rem; }
    .how-head h2 {
      font-family: 'Cormorant Garamond', serif; font-size: clamp(2.8rem, 6vw, 5rem);
      letter-spacing: -0.03em; margin-top: 0.5rem;
    }
    .how-steps {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border); border: 1px solid var(--border);
    }
    @media (max-width: 700px) { .how-steps { grid-template-columns: 1fr 1fr; } }

    .step {
      padding: 2.5rem 2rem; background: var(--light);
      display: flex; flex-direction: column; gap: 1rem;
    }
    .step-num {
      font-family: 'Cormorant Garamond', serif; font-size: 3.5rem;
      color: var(--amber); line-height: 1;
    }
    .step h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; line-height: 1.2; }
    .step p { font-size: 0.85rem; color: var(--muted); line-height: 1.65; }

    /* ─── PRICING (MasterClass-style plans) ──────── */
    .pricing {
      padding: clamp(4rem, 8vw, 8rem) 0;
      background: var(--grain);
      border-bottom: 1px solid var(--border);
    }
    .pricing-head { text-align: center; margin-bottom: 4rem; }
    .pricing-head h2 {
      font-family: 'Cormorant Garamond', serif; font-size: clamp(2.8rem, 5vw, 4.5rem);
      letter-spacing: -0.03em; margin-top: 0.5rem;
    }
    .pricing-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media (max-width: 700px) { .pricing-grid { grid-template-columns: 1fr; } }

    .plan {
      background: var(--light); border: 1px solid var(--border);
      padding: 2.5rem; display: flex; flex-direction: column; gap: 1.5rem;
      position: relative; transition: box-shadow 0.3s;
    }
    .plan:hover { box-shadow: 0 12px 40px rgba(26,24,21,0.12); }
    .plan.featured {
      background: var(--dark); color: var(--light); border-color: var(--dark);
    }
    .plan-badge {
      position: absolute; top: -1px; right: 2rem;
      background: var(--amber); color: var(--dark);
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      padding: 0.3rem 0.8rem;
    }
    .plan-name { font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; }
    .plan.featured .plan-name { color: var(--amber); }
    .plan-price {
      font-family: 'Cormorant Garamond', serif; font-size: 3.5rem; line-height: 1;
      letter-spacing: -0.03em;
    }
    .plan-price sup { font-size: 1.5rem; vertical-align: top; margin-top: 0.5rem; }
    .plan-price sub { font-size: 0.9rem; }
    .plan-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }
    .plan.featured .plan-desc { color: rgba(239,232,218,0.65); }
    .plan-items { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; flex: 1; }
    .plan-items li { display: flex; gap: 0.7rem; font-size: 0.83rem; line-height: 1.5; }
    .plan-items li::before { content: '↳'; color: var(--amber); flex-shrink: 0; }
    .plan.featured .plan-items li { color: rgba(239,232,218,0.8); }
    .plan-btn {
      display: block; text-align: center; text-decoration: none;
      padding: 0.9rem; font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;
      transition: all 0.4s; margin-top: auto; border: none; cursor: pointer;
    }
    .plan-btn-dark { background: var(--dark); color: var(--light); }
    .plan-btn-dark:hover { background: var(--amber); }
    .plan-btn-amber { background: var(--amber); color: var(--dark); }
    .plan-btn-amber:hover { background: var(--light); }
    .plan-btn-outline { background: transparent; border: 1px solid rgba(239,232,218,0.3); color: var(--light); }
    .plan-btn-outline:hover { background: var(--amber); border-color: var(--amber); color: var(--dark); }

    /* ─── FINAL CTA ──────────────────────────────── */
    .final-cta {
      padding: clamp(5rem, 10vw, 10rem) 0;
      background: var(--dark); color: var(--light);
      text-align: center; position: relative; overflow: hidden;
    }
    .final-cta::before {
      content: '';
      position: absolute; top: -40%; left: 50%; transform: translateX(-50%);
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(200,134,44,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .final-cta h2 {
      font-family: 'Cormorant Garamond', serif; font-size: clamp(4rem, 10vw, 9rem);
      line-height: 0.9; letter-spacing: -0.04em; font-weight: 500; font-style: italic;
      margin: 1rem 0 2rem;
    }
    .final-cta h2 em { color: var(--amber); font-style: normal; }
    .final-cta p { color: rgba(239,232,218,0.65); font-size: 1rem; line-height: 1.7; max-width: 40ch; margin: 0 auto 3rem; }
    .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn-wa {
      display: inline-flex; align-items: center; gap: 0.7rem;
      background: var(--amber); color: var(--dark);
      padding: 1.1rem 2.2rem; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
      text-decoration: none; transition: background 0.4s;
    }
    .btn-wa:hover { background: var(--light); }
    .btn-ig {
      display: inline-flex; align-items: center; gap: 0.7rem;
      border: 1px solid rgba(239,232,218,0.3); color: var(--light);
      padding: 1.1rem 2.2rem; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
      text-decoration: none; transition: all 0.4s;
    }
    .btn-ig:hover { background: rgba(239,232,218,0.1); border-color: var(--amber); }

    /* ─── FOOTER ─────────────────────────────────── */
    footer {
      background: #111;
      color: rgba(239,232,218,0.6);
      padding: 3rem clamp(1.5rem, 5vw, 5rem);
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 1rem; font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    footer a { color: inherit; text-decoration: none; transition: color 0.3s; }
    footer a:hover { color: var(--amber); }

    /* ─── SCROLL REVEAL ──────────────────────────── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
    .reveal.visible { opacity: 1; transform: none; }
  </style>

  <!-- ── NAV ── -->
  <nav id="nav">
    <a href="#top" class="nav-logo">Sunflora<span>.</span></a>
    <ul class="nav-links">
      <li><a href="#offerings">Collections</a></li>
      <li><a href="#how">Process</a></li>
      <li><a href="#pricing">Pricing</a></li>
      <li><a href="#testimonials">Love notes</a></li>
    </ul>
