                            data-category={p.category}
                            data-price={p.price}
                            data-rating={p.rating}
                            data-new={p.isNew ? "1" : "0"}
                            aria-label={`${p.name} — ₹${p.price}`}
                        >
                            <div class="card-img-wrap">
                                <img
                                    src={p.img}
                                    alt={p.name}
                                    class="card-img"
                                    loading="lazy"
                                    width={300}
                                    height={300}
                                />
                                {p.tag && (
                                    <span class={`card-tag ${tagClass}`}>
                                        {p.tag}
                                    </span>
                                )}
                                {!p.inStock && (
                                    <div class="out-of-stock-badge">
                                        <span>Sold Out</span>
                                    </div>
                                )}
                                <button
                                    class="card-wishlist"
                                    aria-label={`Wishlist ${p.name}`}
                                    onclick="event.preventDefault(); this.classList.toggle('active');"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                    </svg>
                                </button>
                                {p.inStock && (
                                    <div class="card-cta">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="13"
                                            height="13"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                            <line
                                                x1="3"
                                                y1="6"
                                                x2="21"
                                                y2="6"
                                            />
                                            <path d="M16 10a4 4 0 0 1-8 0" />
                                        </svg>
                                        Buy Now
                                    </div>
                                )}
                            </div>
                            <div class="card-body">
                                <span class="card-cat">{p.category}</span>
                                <h2 class="card-name">{p.name}</h2>
                                <div class="card-rating">
                                    <span class="card-stars">
                                        {"★".repeat(Math.floor(p.rating))}
                                        {"☆".repeat(5 - Math.floor(p.rating))}
                                    </span>
                                    <span class="card-rating-num">
                                        {p.rating}
                                    </span>
                                    <span class="card-rating-count">
                                        ({p.reviews})
                                    </span>
                                </div>
                                <div class="card-price-row">
                                    <span class="card-price">₹{p.price}</span>
                                    <span class="card-mrp">₹{p.mrp}</span>
                                    <span class="card-disc">{disc}% off</span>
                                </div>
                            </div>
                        </a>
                    );
                })
            }
        </div>

        <!-- Empty state -->
        <div class="empty-state" id="empty-state">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                ><path
                    d="M3 3l1.88 5.76a1 1 0 0 0 .95.69h14.34a1 1 0 0 0 .95-.69L23 3"
                ></path><path d="M9 14v1a3 3 0 0 0 6 0v-1"></path><path
                    d="M3 3H2"></path>
            </svg>
            <p>Nothing here yet — try another category.</p>
        </div>
    </section>

    <!-- ── LOAD MORE ── -->
    <div class="load-more-wrap" id="load-more-wrap" style="display:none;">
        <button class="load-more-btn" id="load-more-btn">
            Load more pieces
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path>
            </svg>
        </button>
    </div>

    <!-- ── RECOMMENDATIONS ── -->
    <div class="reco-section" id="reco-section">
        <div class="reco-divider">
            <div class="reco-divider-inner">
                <div>
                    <p class="reco-eyebrow">Curated for you</p>
                    <h2 class="reco-title">
                        Explore our <em>recommendations</em>
                    </h2>
                </div>
                <a href="#" class="reco-arrow-link">
                    See all
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M7 17L17 7"></path><path d="M7 7h10v10"
                        ></path>
                    </svg>
                </a>
            </div>
            <div class="reco-grid">
                {
                    recommendations.map((p) => {
                        const disc = Math.round((1 - p.price / p.mrp) * 100);
                        const tagClass =
                            p.tag === "New"
                                ? "tag-new"
                                : p.tag === "Top Rated" || p.tag === "Fan Fav"
                                  ? "tag-gold"
                                  : "";
                        return (
                            <a
                                href={`/productdetail?id=${p.id}`}
                                class="prod-card"
                                aria-label={`${p.name} — ₹${p.price}`}
                            >
                                <div class="card-img-wrap">
                                    <img
                                        src={p.img}
                                        alt={p.name}
                                        class="card-img"
                                        loading="lazy"
                                    />
                                    {p.tag && (
                                        <span class={`card-tag ${tagClass}`}>
                                            {p.tag}
                                        </span>
                                    )}
                                    <button
                                        class="card-wishlist"
                                        aria-label={`Wishlist ${p.name}`}
                                        onclick="event.preventDefault(); this.classList.toggle('active');"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="14"
                                            height="14"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                        </svg>
                                    </button>
                                    <div class="card-cta">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="13"
                                            height="13"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                            <line
                                                x1="3"
                                                y1="6"
                                                x2="21"
                                                y2="6"
                                            />
                                            <path d="M16 10a4 4 0 0 1-8 0" />
                                        </svg>
                                        Buy Now
                                    </div>
                                </div>
                                <div class="card-body">
                                    <span class="card-cat">{p.category}</span>
                                    <h2 class="card-name">{p.name}</h2>
                                    <div class="card-rating">
                                        <span class="card-stars">
                                            {"★".repeat(Math.floor(p.rating))}
                                            {"☆".repeat(
                                                5 - Math.floor(p.rating),
                                            )}
                                        </span>
                                        <span class="card-rating-num">
                                            {p.rating}
                                        </span>
                                        <span class="card-rating-count">
                                            ({p.reviews})
                                        </span>
                                    </div>
                                    <div class="card-price-row">
                                        <span class="card-price">
                                            ₹{p.price}
                                        </span>
                                        <span class="card-mrp">₹{p.mrp}</span>
                                        <span class="card-disc">
                                            {disc}% off
                                        </span>
                                    </div>
                                </div>
                            </a>
                        );
                    })
                }
            </div>
        </div>
    </div>

    <!-- ── FOOTER STRIP ── -->
    <div class="shop-footer-strip">
        <span
            >© {new Date().getFullYear()} Sunflora Studio — Handmade with care.</span
        >
        <span>Hooked in India · <a href="/">Back to home</a></span>
    </div>

    <script is:inline>
        // ── Category filter ──────────────────────────────────────────
        const catBtns = document.querySelectorAll(".cat-btn");
        const grid = document.getElementById("product-grid");
        const cards = Array.from(grid.querySelectorAll(".prod-card"));
        const countEl = document.getElementById("result-count");
        const emptyEl = document.getElementById("empty-state");
        const sortSel = document.getElementById("sort-select");

        let activeCategory = "All";

        // Parse query parameter to pre-filter
        const urlParams = new URLSearchParams(window.location.search);
        const categoryParam = urlParams.get("category");
        if (categoryParam) {
            const decodedCat = decodeURIComponent(categoryParam);
            const matchedBtn = Array.from(catBtns).find(
                (btn) =>
                    btn.dataset.cat.toLowerCase() === decodedCat.toLowerCase(),
            );
            if (matchedBtn) {
                catBtns.forEach((b) => {
                    b.classList.remove("active");
                    b.setAttribute("aria-selected", "false");
                });
                matchedBtn.classList.add("active");
                matchedBtn.setAttribute("aria-selected", "true");
                activeCategory = matchedBtn.dataset.cat;

                // Scroll the category button into view on mobile
                matchedBtn.scrollIntoView({
                    behavior: "auto",
                    block: "nearest",
                    inline: "center",
                });
            }
        }

        function filterAndSort() {
            const sort = sortSel.value;

            // Determine filtered set
            let filtered = cards.filter((c) => {
                if (activeCategory === "All") return true;
                return c.dataset.category === activeCategory;
            });

            // Sort
            filtered = [...filtered].sort((a, b) => {
                if (sort === "price-asc")
                    return Number(a.dataset.price) - Number(b.dataset.price);
                if (sort === "price-desc")
                    return Number(b.dataset.price) - Number(a.dataset.price);
                if (sort === "rating")
                    return Number(b.dataset.rating) - Number(a.dataset.rating);
                if (sort === "new")
                    return Number(b.dataset.new) - Number(a.dataset.new);
                return 0; // default = DOM order
            });

            // Hide all first
            cards.forEach((c) => {
                c.style.display = "none";
                c.style.animationName = "none";
            });

            // Re-show filtered and trigger animation
            filtered.forEach((c, i) => {
                c.style.display = "";
                // Restart animation with staggered delay
                requestAnimationFrame(() => {
                    c.style.animationName = "";
                    c.style.animationDelay = i * 0.06 + "s";
                    c.style.animationDuration = "0.45s";
                    c.style.opacity = "0";
                    c.style.animationName = "cardIn";
                });
            });

            // Update count
            countEl.textContent = filtered.length;

            // Empty state
            emptyEl.classList.toggle("show", filtered.length === 0);
        }

        catBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                catBtns.forEach((b) => {
                    b.classList.remove("active");
                    b.setAttribute("aria-selected", "false");
                });
                btn.classList.add("active");
                btn.setAttribute("aria-selected", "true");
                activeCategory = btn.dataset.cat;

                // Scroll active btn into view on mobile
                btn.scrollIntoView({
                    behavior: "smooth",
                    block: "nearest",
                    inline: "center",
                });

                filterAndSort();
            });
        });

        sortSel.addEventListener("change", filterAndSort);

        // Run initial filter on page load
        filterAndSort();

        // ── Wishlist persistence (session) ───────────────────────────
        document.querySelectorAll(".card-wishlist").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation();
                btn.classList.toggle("active");
                const svgPath = btn.querySelector("path");
                if (svgPath) {
                    const isActive = btn.classList.contains("active");
                    svgPath.setAttribute(
                        "fill",
                        isActive ? "currentColor" : "none",
                    );
                }
            });
        });

        // ── Recommendation section reveal on scroll ──────────────────
        const recoSection = document.getElementById("reco-section");
        if (recoSection) {
            const recoCards = recoSection.querySelectorAll(".prod-card");
            recoCards.forEach((c) => {
                c.style.opacity = "0";
                c.style.animationName = "none";
            });

            const recoObserver = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            recoCards.forEach((c, i) => {
                                c.style.animationDelay = i * 0.1 + "s";
                                c.style.animationDuration = "0.55s";
                                c.style.animationName = "cardIn";
                            });
                            recoObserver.disconnect();
                        }
                    });
                },
                { threshold: 0.1 },
            );
            recoObserver.observe(recoSection);
        }
    </script>
</Layout>
