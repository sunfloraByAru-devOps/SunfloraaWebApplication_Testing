      { num: "04", name: "Spidey Hanging Charm", price: 299, mrp: 399, tag: "Limited", img: SPIDEY.src, id: 4 }
    ],
    images: [SPIDEY.src, DINO.src, PRODUCT_MAIN.src, PRODUCT_DETAIL.src]
  },
  12: {
    num: "12",
    name: "Sunrise Amigurumi",
    brand: "Sunflora Studio",
    tag: "Fan Fav",
    tagline: "Bring the morning glow inside.",
    sku: "SFL-SRA-012",
    rating: 5.0,
    reviewCount: 15,
    price: 699,
    mrp: 899,
    description: "A beautiful variation of our sunshine plushie featuring pastel morning glow sunrise hues (soft pinks, butter creams and corals). Perfect for soft aesthetics.",
    sizes: [
      { label: "Standard", cm: "12 cm", price: 699, mrp: 899 }
    ],
    colors: [
      { name: "Morning Glow Pink", hex: "#FCA5A5" },
      { name: "Sunrise Orange", hex: "#FDBA74" }
    ],
    details: [
      { label: "Material", value: "Anti-pill acrylic yarn" }
    ],
    includes: [
      "Handcrocheted Sunrise Amigurumi Piece",
      "Numbered certificate of craft label"
    ],
    reviews: [
      { id: 1, stars: 5, title: "Pure pastel magic!", date: "26 May 2026", author: "Kriti", verified: true, body: "The colors are absolutely beautiful.", photos: [] }
    ],
    ratingBreakdown: [{ stars: 5, count: 15 }],
    totalRatings: 15,
    customerInsights: [{ label: "Color Aesthetics", options: [{ text: "Perfect", pct: 100 }] }],
    productCode: "SFL-SRA-012",
    related: [
      { num: "01", name: "Sunshine Amigurumi", price: 649, mrp: 899, tag: "Best Seller", img: PRODUCT_CLOSE.src, id: 1 },
      { num: "03", name: "Sun & Moon Stem", price: 449, mrp: 599, tag: "Set of 2", img: SUNMOON.src, id: 3 }
