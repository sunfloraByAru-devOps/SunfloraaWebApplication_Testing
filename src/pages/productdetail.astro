        <div class="size-grid" id="sizes-container">
          {product.sizes.map((s, i) => (
            <button
              class={`size-btn${i === 0 ? ' active' : ''}`}
              data-price={s.price}
              data-mrp={product.mrp + (i * 200)}
              aria-pressed={i === 0 ? "true" : "false"}
