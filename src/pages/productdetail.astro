  .related-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
  .related-card:hover .related-img-wrap img { transform: scale(1.04); }
  .related-badge {
    position: absolute; top: 8px; left: 8px;
    background: var(--dark); color: #fff;
    font-size: 9px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 2px 6px; border-radius: 2px;
  }
  .related-body { padding: 0.75rem; display: flex; flex-direction: column; gap: 4px; }
  .related-brand { font-size: 0.65rem; color: var(--amber); letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; }
  .related-name { font-size: 0.82rem; font-weight: 500; line-height: 1.3; color: var(--dark); }
  .related-price-row { display: flex; align-items: baseline; gap: 6px; margin-top: 4px; }
  .related-price { font-weight: 600; font-size: 0.85rem; }
  .related-mrp  { font-size: 0.72rem; color: var(--muted); text-decoration: line-through; }
  .related-disc { font-size: 0.7rem; color: var(--red); font-weight: 600; }

  /* ── FOOTER ── */
  footer {
    background: var(--dark); color: rgba(255,255,255,0.5);
    padding: 1.5rem clamp(1rem, 3vw, 3rem);
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
  }
  footer a { color: inherit; text-decoration: none; transition: color 0.2s; }
  footer a:hover { color: var(--amber); }

  /* ── MOBILE STICKY BAR ── */
  .mobile-sticky {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    background: var(--light); border-top: 1px solid var(--border);
    padding: 0.75rem 1rem;
    align-items: center; gap: 0.75rem;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
  }
  @media (max-width: 900px) { .mobile-sticky { display: flex; } }
  .mobile-sticky-price { flex: 1; }
  .mobile-sticky-price .ms-name { font-size: 0.78rem; font-weight: 500; color: var(--dark); }
  .mobile-sticky-price .ms-price { font-size: 1.1rem; font-weight: 600; color: var(--dark); }
  .mobile-sticky-btn {
    flex: 1; display: flex; align-items: center; justify-content: center;
    background: var(--dark); color: #fff;
    padding: 0.75rem 1rem;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    border: none; border-radius: var(--radius); cursor: pointer;
    text-decoration: none; transition: background 0.2s;
  }
  .mobile-sticky-btn:hover { background: var(--amber); }

  .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
</style>


