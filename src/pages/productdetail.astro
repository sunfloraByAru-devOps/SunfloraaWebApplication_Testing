<script is:inline define:vars={{ productsJson }}>
  const products = JSON.parse(productsJson);

  // 1. Get Product from URL Params
  const urlParams = new URLSearchParams(window.location.search);
  const productId = parseInt(urlParams.get('id')) || 1;
  const product = products[productId] || products[1];

  // 2. Hydration Function
  function hydratePDP(product) {
    // Page metadata & titles
    document.title = `${product.name} — ${product.brand}`;
    const metaDesc = document.querySelector('meta[name="description"]');
    if (metaDesc) metaDesc.setAttribute('content', product.description);

    const breadcrumbCurrent = document.querySelector('.breadcrumb-current');
    if (breadcrumbCurrent) breadcrumbCurrent.textContent = product.name;

    const breadcrumbParent = document.querySelector('.breadcrumb a:nth-of-type(2)');
    if (breadcrumbParent) {
      const cat = product.category || (product.num === "01" || product.num === "06" || product.num === "07" || product.num === "12" ? "Amigurumi" : product.num === "02" || product.num === "04" || product.num === "11" ? "Keychains" : product.num === "03" || product.num === "08" ? "Flower Stems" : product.num === "09" ? "Bouquets" : "Wall Hangings");
      breadcrumbParent.textContent = cat;
      breadcrumbParent.href = "/productlist?category=" + encodeURIComponent(cat);
    }

    const prodBrand = document.querySelector('.prod-brand');
    if (prodBrand) prodBrand.textContent = product.brand;
    const prodTitle = document.querySelector('.prod-title');
    if (prodTitle) prodTitle.textContent = product.name;

    const imgTag = document.getElementById('img-tag');
    if (imgTag) {
      if (product.tag) {
        imgTag.textContent = product.tag;
        imgTag.style.display = '';
      } else {
        imgTag.style.display = 'none';
      }
    }

    // Ratings bar
    const ratingVal = document.getElementById('rating-val');
    if (ratingVal) ratingVal.textContent = product.rating;
    const ratingCount = document.querySelector('.rating-count');
    if (ratingCount) ratingCount.textContent = product.reviewCount + " Ratings";
    const ratingSku = document.querySelector('.rating-sku');
    if (ratingSku) ratingSku.textContent = "SKU: " + product.sku;

    // Price block
    const activePrice = document.getElementById('active-price');
    const activeMrp = document.getElementById('active-mrp');
    const activeDisc = document.getElementById('active-disc');
    const stickyPrice = document.getElementById('sticky-price');
    const stickyName = document.getElementById('sticky-name');

    const discount = Math.round((1 - product.price / product.mrp) * 100);
    if (activePrice) activePrice.textContent = '₹ ' + product.price;
    if (activeMrp) activeMrp.textContent = 'MRP ₹ ' + product.mrp;
    if (activeDisc) activeDisc.textContent = '(' + discount + '% OFF)';
    if (stickyPrice) stickyPrice.textContent = '₹ ' + product.price;
    if (stickyName) stickyName.textContent = product.name;

    // 3. Color swatches setup
    const colorLabel = document.getElementById('color-label');
    if (colorLabel) colorLabel.textContent = '— ' + product.colors[0].name;

    const colorContainer = document.getElementById('color-container');
    if (colorContainer) {
      colorContainer.innerHTML = product.colors.map((c, i) => `
        <button
          class="color-swatch${i === 0 ? ' active' : ''}${c.border ? ' border-swatch' : ''}"
          style="background:${c.hex};"
          data-name="${c.name}"
          aria-label="${c.name}"
          title="${c.name}"
        ></button>
      `).join('');

      const swatches = colorContainer.querySelectorAll('.color-swatch');
      swatches.forEach(swatch => {
        swatch.addEventListener('click', () => {
          swatches.forEach(s => s.classList.remove('active'));
          swatch.classList.add('active');
          if (colorLabel) colorLabel.textContent = '— ' + swatch.dataset.name;
        });
      });
    }

    // 4. Size grid setup
    const sizesContainer = document.getElementById('sizes-container');
    if (sizesContainer) {
      sizesContainer.innerHTML = product.sizes.map((s, i) => `
        <button
          class="size-btn${i === 0 ? ' active' : ''}"
          data-price="${s.price}"
          data-mrp="${s.mrp || (product.mrp + (i * 200))}"
          aria-pressed="${i === 0 ? "true" : "false"}"
        >
          <span class="sz-label">${s.label}</span>
          <span class="sz-cm">${s.cm}</span>
          <span class="sz-price">₹ ${s.price}</span>
        </button>
      `).join('');

      const sizeBtns = sizesContainer.querySelectorAll('.size-btn');
      sizeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          sizeBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed','false'); });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed','true');
          const p = parseInt(btn.dataset.price);
          const mrp = parseInt(btn.dataset.mrp);
          const disc = Math.round((1 - p/mrp)*100);
          if (activePrice) activePrice.textContent = '₹ ' + p;
          if (activeMrp) activeMrp.textContent = 'MRP ₹ ' + mrp;
          if (activeDisc) activeDisc.textContent = '(' + disc + '% OFF)';
          if (stickyPrice) stickyPrice.textContent = '₹ ' + p;
        });
      });
    }

    // 5. Accordion Description & details table
    const prodDescPara = document.getElementById('product-description');
    if (prodDescPara) prodDescPara.textContent = product.description;

    const detailsTableBody = document.getElementById('details-table-body');
    if (detailsTableBody) {
      detailsTableBody.innerHTML = product.details.map(d => `
        <tr>
          <td>${d.label}</td>
          <td>${d.value}</td>
        </tr>
      `).join('');
    }

    const includesContainer = document.getElementById('includes-container');
    if (includesContainer) {
      includesContainer.innerHTML = product.includes.map(item => `
        <div class="includes-item">
          <svg class="includes-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          ${item}
        </div>
      `).join('');
    }

    // 6. Reviews & ratings hydration
    const ratingScoreNum = document.querySelector('.rating-score-num');
    if (ratingScoreNum) ratingScoreNum.textContent = product.rating;

    const ratingScoreTotal = document.getElementById('rating-score-total');
    if (ratingScoreTotal) {
      ratingScoreTotal.innerHTML = `${(product.totalRatings / 1000).toFixed(1)}k<br/>Verified Buyers`;
    }

    const ratingBarsContainer = document.getElementById('rating-bars-container');
    if (ratingBarsContainer) {
      ratingBarsContainer.innerHTML = product.ratingBreakdown.map(row => {
        const pct = Math.round((row.count / product.totalRatings) * 100);
        const isLow = row.stars >= 2;
        return `
          <div class="rating-bar-row">
            <span class="rating-bar-label">${row.stars}</span>
            <span class="rating-bar-star">★</span>
            <div class="rating-bar-track">
              <div class="rating-bar-fill${isLow ? ' low' : ''}" style="width:${pct}%"></div>
            </div>
            <span class="rating-bar-count">${row.count.toLocaleString('en-IN')}</span>
          </div>
        `;
      }).join('');
    }

    const insightsContainer = document.getElementById('insights-container');
    if (insightsContainer) {
      insightsContainer.innerHTML = product.customerInsights.map(ins => `
        <div class="insight-row">
          <div class="insight-row-label">${ins.label}</div>
          <div class="insight-bar-wrap">
            <div class="insight-bar-track">
              <div class="insight-bar-fill" style="width:${ins.options[0].pct}%"></div>
            </div>
            <span class="insight-bar-label">${ins.options[0].text} (${ins.options[0].pct}%)</span>
          </div>
        </div>
      `).join('');
    }

    const dialogInsightsContainer = document.getElementById('dialog-insights-container');
    if (dialogInsightsContainer) {
      dialogInsightsContainer.innerHTML = product.customerInsights.map(ins => `
        <div class="dialog-insight-group">
          <div class="dialog-insight-label">${ins.label}</div>
          ${ins.options.map((opt, oi) => `
            <div class="dialog-bar-row">
              <span class="dialog-bar-name${oi === 0 ? ' bold' : ''}">${opt.text} (${opt.pct}%)</span>
              <div class="dialog-bar-track">
                <div class="dialog-bar-fill${oi === 0 ? ' primary' : ''}" style="width:${opt.pct}%"></div>
              </div>
            </div>
          `).join('')}
        </div>
      `).join('');
    }

    const reviewsListCount = document.querySelector('.reviews-list-count');
    if (reviewsListCount) {
      reviewsListCount.textContent = `(${product.reviews.length * 11357} reviews)`;
    }

    const reviewsListContainer = document.getElementById('reviews-list-container');
    if (reviewsListContainer) {
      reviewsListContainer.innerHTML = product.reviews.map(r => {
        const starColor = r.stars >= 4 ? '' : r.stars === 3 ? ' mid' : ' low';
        const words = r.body.split(' ');
        const preview = words.slice(0, 22).join(' ');
        const overflow = words.slice(22).join(' ');
        
        let bodyHtml = `<span class="review-body-text">${preview}</span>`;
        if (words.length > 22) {
          bodyHtml += `
            <span class="review-body-overflow hidden" id="overflow-${r.id}"> ${overflow}</span>
            <button class="review-read-more" data-id="${r.id}" id="rm-${r.id}">... Read more</button>
          `;
        }

        return `
          <div class="review-card">
            <div class="review-top">
              <span class="review-stars-pill${starColor}">
                ${r.stars} ★
              </span>
              <span class="review-title">${r.title}</span>
            </div>

            <div class="review-body-wrap">
              ${bodyHtml}
            </div>

            ${r.photos && r.photos.length > 0 ? `
              <div class="review-photos">
                ${r.photos.map((photo, pi) => `
                  <div class="review-photo">
                    <img src="${photo}" alt="Review photo ${pi + 1}" loading="lazy" />
                  </div>
                `).join('')}
              </div>
            ` : ''}

            <div class="review-meta">
              <span class="review-author">${r.author}</span>
              ${r.verified ? `
                <span class="review-verified">
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  Verified Buyer
                </span>
              ` : ''}
              <span class="review-date">${r.date}</span>
            </div>
            <div class="review-helpful">
              Was this review helpful?
              <button class="helpful-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                Yes (${r.helpful})
              </button>
              <button class="helpful-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                No (${r.unhelpful || 0})
              </button>
            </div>
          </div>
        `;
      }).join('');

      // Helpful buttons handlers
      reviewsListContainer.querySelectorAll('.helpful-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          btn.style.borderColor = 'var(--dark)';
          btn.style.color = 'var(--dark)';
        });
      });

      // Read more handlers
      reviewsListContainer.querySelectorAll('.review-read-more').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id;
          const overflow = document.getElementById('overflow-' + id);
          if (overflow) {
            const isHidden = overflow.classList.contains('hidden');
            if (isHidden) {
              overflow.classList.remove('hidden');
              btn.textContent = ' Read less';
            } else {
              overflow.classList.add('hidden');
              btn.textContent = '... Read more';
            }
          }
        });
      });
    }

    const viewAllReviews = document.querySelector('.view-all-reviews');
    if (viewAllReviews) {
      viewAllReviews.textContent = `View all ${product.reviews.length * 11357} reviews`;
    }

    const productCodeVal = document.getElementById('product-code-val');
    if (productCodeVal) productCodeVal.textContent = product.productCode;

    // 7. Related grid cards
    const relatedGridContainer = document.getElementById('related-grid-container');
    if (relatedGridContainer) {
      relatedGridContainer.innerHTML = product.related.map(o => {
        const relDisc = Math.round((1 - o.price / o.mrp) * 100);
        return `
          <a href="/productdetail?id=${o.id}" class="related-card">
            <div class="related-img-wrap">
              <img src="${o.img}" alt="${o.name}" />
              ${o.tag ? `<span class="related-badge">${o.tag}</span>` : ''}
            </div>
            <div class="related-body">
              <span class="related-brand">Sunflora Studio</span>
              <span class="related-name">${o.name}</span>
              <div class="related-price-row">
                <span class="related-price">₹ ${o.price}</span>
                <span class="related-mrp">₹ ${o.mrp}</span>
                <span class="related-disc">(${relDisc}% OFF)</span>
              </div>
            </div>
          </a>
        `;
      }).join('') + `
        <a href="/#offerings" class="related-card" style="align-items:center;justify-content:center;min-height:200px;border-style:dashed;background:transparent;color:var(--muted);">
          <div style="text-align:center;padding:1.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <p style="margin-top:0.5rem;font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;">View All</p>
          </div>
        </a>
      `;
    }

    // 8. Gallery and thumb strip hydration
    const mainImg = document.getElementById('main-img');
    const thumbStrip = document.getElementById('thumb-strip');
    if (thumbStrip && mainImg) {
      mainImg.src = product.images[0];
      mainImg.alt = product.name;

      thumbStrip.innerHTML = product.images.map((src, i) => `
        <button
          class="thumb-btn${i === 0 ? ' active' : ''}"
          data-index="${i}"
          data-src="${src}"
          aria-label="View image ${i + 1}"
        >
          <img src="${src}" alt="" loading="lazy" />
        </button>
      `).join('');

      let current = 0;
      const thumbs = Array.from(thumbStrip.querySelectorAll('.thumb-btn'));

      function setImage(index) {
        if (index === current) return;
        mainImg.classList.add('fading');
        setTimeout(() => {
          mainImg.src = thumbs[index].dataset.src;
          mainImg.classList.remove('fading');
        }, 200);
        thumbs[current].classList.remove('active');
        thumbs[index].classList.add('active');
        current = index;
      }

      thumbs.forEach((btn, i) => btn.addEventListener('click', () => setImage(i)));

      const prevBtn = document.getElementById('img-prev');
      const nextBtn = document.getElementById('img-next');

      if (prevBtn) {
        const newPrev = prevBtn.cloneNode(true);
        prevBtn.parentNode.replaceChild(newPrev, prevBtn);
        newPrev.addEventListener('click', () => setImage((current - 1 + thumbs.length) % thumbs.length));
      }
      if (nextBtn) {
        const newNext = nextBtn.cloneNode(true);
        nextBtn.parentNode.replaceChild(newNext, nextBtn);
        newNext.addEventListener('click', () => setImage((current + 1) % thumbs.length));
      }
    }
  }

  // Hydrate UI with URL parameter product or default to Product 1
  hydratePDP(product);

  // 9. Standard Accordion logic (independent of specific product layout rebuild)
  const triggers = document.querySelectorAll('.accordion-trigger');
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      triggers.forEach(t => {
        t.setAttribute('aria-expanded','false');
        const body = document.getElementById(t.dataset.target);
        if (body) body.classList.remove('open');
      });
      if (!expanded) {
        trigger.setAttribute('aria-expanded','true');
        const body = document.getElementById(trigger.dataset.target);
        if (body) body.classList.add('open');
      }
    });
  });

  // 10. Pincode check
  const pincodeInput = document.getElementById('pincode-input');
  const pincodeBtn   = document.getElementById('pincode-btn');
  const deliveryNote = document.getElementById('delivery-note');
  if (pincodeBtn && pincodeInput) {
    pincodeBtn.addEventListener('click', () => {
      const val = pincodeInput.value.trim();
      if (val.length === 6 && /^\d+$/.test(val)) {
        deliveryNote.style.display = 'flex';
      }
    });
    pincodeInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') pincodeBtn.click();
    });
  }

  // 11. Wishlist toggle
  const wishlistBtn = document.getElementById('wishlist-btn');
  if (wishlistBtn) {
    let wishlisted = false;
    wishlistBtn.addEventListener('click', () => {
      wishlisted = !wishlisted;
      wishlistBtn.style.color      = wishlisted ? 'var(--red)' : '';
      wishlistBtn.style.background = wishlisted ? '#fff0ef'    : '';
      wishlistBtn.style.borderColor= wishlisted ? 'var(--red)' : '';
      const icon = wishlistBtn.querySelector('svg');
      if (icon) icon.setAttribute('fill', wishlisted ? 'currentColor' : 'none');
    });
  }

  // 12. Insights Dialog
  const overlay      = document.getElementById('insights-overlay');
  const viewDetailsBtn = document.getElementById('view-details-btn');
  const closeBtn     = document.getElementById('insights-close');

  if (viewDetailsBtn && overlay && closeBtn) {
    viewDetailsBtn.addEventListener('click', () => {
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
    closeBtn.addEventListener('click', () => {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  }

  // 13. Mobile sticky: show when panel scrolls out
  const mobileSticky = document.getElementById('mobile-sticky');
  const productPanel = document.querySelector('.product-panel');
  if (mobileSticky && productPanel) {
    const obs = new IntersectionObserver(([entry]) => {
      mobileSticky.style.transform = entry.isIntersecting ? 'translateY(100%)' : 'translateY(0)';
    }, { threshold: 0 });
    obs.observe(productPanel);
  }
  if (mobileSticky) {
    mobileSticky.style.transform = 'translateY(100%)';
    mobileSticky.style.transition = 'transform 0.3s';
  }
</script>

</Layout>