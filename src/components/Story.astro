---
import { getImageUrl } from '../lib/images';
import FOUNDER from '../assets/ldki.jpg';   

const founderUrl = getImageUrl('story/founder.jpg', 'gallery-images') || FOUNDER.src;
---

<section id="story" data-testid="brand-story" class="py-24 md:py-32 bg-[#E5DFD1] border-y border-[rgba(26,24,21,0.08)]">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 grid grid-cols-12 gap-10 lg:gap-20 items-center">

    <div class="col-span-12 lg:col-span-5 fade-up">
      <div class="relative">
        <div class="absolute -inset-4 border border-[#C8862C] -z-10 translate-x-5 translate-y-5"></div>
        <img src={founderUrl} alt="Sunflora founder" data-testid="founder-image" class="w-full aspect-[4/5] object-cover" />
      </div>
    </div>

    <div class="col-span-12 lg:col-span-7">
      <p class="fade-up uppercase tracking-[0.28em] text-xs text-[#C8862C] mb-5">
        The hands behind Sunflora
      </p>
      <h2 class="fade-up font-serif-display text-4xl md:text-5xl lg:text-6xl tracking-tight text-[#1A1815] leading-[1.1]">
        A studio of <em>slow stitches</em>, sunlit afternoons, and quiet rebellion against the disposable.
      </h2>
      <div class="fade-up mt-8 space-y-5 text-[15px] md:text-[17px] leading-[1.8] text-[#4A453E] max-w-xl">
        <p>
          Sunflora began on a verandah, with one ball of mustard yarn and an idea that
          warmth could be something you hold. Each piece is hooked by hand — sometimes
          across days — never replicated by machine.
        </p>
        <p>
          We are small on purpose. We choose soft cottons, we name each character, and
          we tuck a little note inside every package. Because the things that stay with
          you are rarely the ones made in a hurry.
        </p>
      </div>
      <div class="fade-up mt-10 flex items-center gap-6 flex-wrap">
        <div class="flex items-baseline gap-3">
          <span class="font-serif-display text-5xl text-[#1A1815]">3+</span>
          <span class="text-xs uppercase tracking-[0.2em] text-[#4A453E]">years of stitching</span>
        </div>
        <span class="w-px h-10 bg-[rgba(26,24,21,0.2)]"></span>
        <div class="flex items-baseline gap-3">
          <span class="font-serif-display text-5xl text-[#1A1815]">800+</span>
          <span class="text-xs uppercase tracking-[0.2em] text-[#4A453E]">happy homes</span>
        </div>
      </div>
    </div>
  </div>
</section>