---
import HERO from '../assets/sun_on_desk.png';
---

<section id="top" data-testid="hero-section" class="relative pt-36 md:pt-44 pb-24 md:pb-32 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 grid grid-cols-12 gap-8 items-end">

    <div class="col-span-12 lg:col-span-7 hero-text-block">
      <div class="flex items-center gap-3 mb-8 fade-up">
        <span class="w-10 h-px bg-[#C8862C]"></span>
        <span class="uppercase tracking-[0.28em] text-xs text-[#C8862C] font-medium">
          Est. handmade — one stitch at a time
        </span>
      </div>
<h1 class="font-hero-heading text-[56px] sm:text-7xl lg:text-[112px] leading-[0.95] tracking-tighter text-[#1A1815]">
  Soft little <em class="italic font-light">things</em><br>
  made <span class="squiggle">slowly</span>,<br>
  made with <span class="text-[#C8862C] italic">love</span>.
</h1>
      <p class="fade-up mt-10 max-w-xl text-[15px] md:text-[17px] leading-[1.7] text-[#4A453E]">
        Sunflora is a small crochet studio crafting heirloom-feel keepsakes —
        sun-bright amigurumi, blooming flowers, and tiny companions that travel
        on bag straps and bedside tables. Each piece is hooked, stitched, and
        whispered to by hand.
      </p>

      <div class="fade-up mt-10 flex flex-wrap items-center gap-5">
        <a
          href="#featured"
          data-testid="hero-explore-button"
          class="inline-flex items-center gap-2 bg-[#1A1815] text-[#EFE8DA] px-7 py-4 text-sm tracking-wider uppercase hover:bg-[#C8862C] transition-colors duration-500"
        >
          Explore the collection
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a
          href="#story"
          data-testid="hero-story-button"
          class="inline-flex items-center gap-2 text-[#1A1815] text-sm tracking-wider uppercase border-b border-[#1A1815] pb-1 hover:text-[#C8862C] hover:border-[#C8862C] transition-colors"
        >
          Our story
        </a>
      </div>

      <div class="fade-up mt-16 flex items-center gap-8 text-xs uppercase tracking-[0.2em] text-[#4A453E]">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
          Hand-crocheted
        </div>
        <div class="hidden sm:flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Small batch
        </div>
        <div class="hidden md:flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.88 5.76a1 1 0 0 0 .95.69h6.05l-4.9 3.56a1 1 0 0 0-.36 1.12L17.5 20l-4.9-3.56a1 1 0 0 0-1.18 0L6.5 20l1.88-5.87a1 1 0 0 0-.36-1.12L3.12 9.45h6.05a1 1 0 0 0 .95-.69L12 3z"/></svg>
          Custom welcome
        </div>
      </div>
    </div>

    <div class="col-span-12 lg:col-span-5 relative hero-img-block">
      <div class="absolute -inset-4 bg-[#C8862C]/15 -z-10 translate-x-6 translate-y-6"></div>
      <img
        src={HERO.src}
        alt="Crochet sunshine on pegboard"
        data-testid="hero-image"
        class="w-full aspect-[4/5] object-cover grayscale-[0.05]"
      />
      <div class="absolute -bottom-6 -left-6 bg-[#EFE8DA] border border-[rgba(26,24,21,0.12)] px-5 py-4 max-w-[220px]">
        <p class="font-serif-display italic text-[#1A1815] text-lg leading-snug">
          "She brings the sun indoors."
        </p>
        <p class="text-[10px] uppercase tracking-[0.2em] text-[#4A453E] mt-2">— Anika, returning customer</p>
      </div>
    </div>
  </div>

  <div class="hidden md:flex absolute bottom-6 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-[10px] uppercase tracking-[0.3em] text-[#4A453E]">
    <span>Scroll</span>
    <span class="w-px h-12 bg-[#4A453E] animate-pulse"></span>
  </div>
</section>

<style>
  .hero-text-block > * {
    opacity: 0;
    transform: translateY(28px);
    animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-text-block > *:nth-child(1) { animation-delay: 0.05s; }
  .hero-text-block > *:nth-child(2) { animation-delay: 0.17s; }
  .hero-text-block > *:nth-child(3) { animation-delay: 0.29s; }
  .hero-text-block > *:nth-child(4) { animation-delay: 0.41s; }
  .hero-text-block > *:nth-child(5) { animation-delay: 0.53s; }

  .hero-img-block {
    opacity: 0;
    transform: translateY(40px);
    animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
