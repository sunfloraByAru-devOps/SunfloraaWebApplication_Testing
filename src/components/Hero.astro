---
import BG_EMPTY from '../assets/ChatGPT Image May 24, 2026, 03_59_57 PM.png';
import BG_FULL from '../assets/ChatGPT Image May 24, 2026, 03_59_49 PM.png';
---

<div class="hero-wrap" id="heroWrap">
  <div class="hero" id="hero">
    <div class="bg-layer bg-full" id="bgFull" style={`background-image: url('${BG_FULL.src}');`}></div>
    <div class="bg-layer bg-empty" id="bgEmpty" style={`background-image: url('${BG_EMPTY.src}');`}></div>

    <div class="edge-fade"></div>

    <!-- STRONGER overlay — covers full left 42% solidly, then fades -->
    <div class="bg-overlay"></div>

    <div class="content">
      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">EST. HANDMADE — ONE STITCH AT A TIME</span>
      </div>

      <h1 class="headline">
        <span class="line1">Your desk misses</span>
        <span class="line2">something alive.</span>
      </h1>

      <p class="sub">
        Handcrocheted companions, flowers,<br />
        and sunshine — made slowly,<br />
        made to stay.
      </p>

      <div class="cta-row">
        <button class="btn-primary" onclick="document.getElementById('featured')?.scrollIntoView({ behavior: 'smooth' })">Explore the collection</button>
        <button class="btn-ghost" onclick="document.getElementById('story')?.scrollIntoView({ behavior: 'smooth' })">Our story</button>
      </div>
    </div>

    <div class="tag absence-tag" id="absenceTag">
      <span class="tag-dot"></span>
      <span class="tag-text">SOMETHING'S MISSING...</span>
    </div>

    <div class="tag presence-tag" id="presenceTag">
      <span class="tag-dot"></span>
      <span class="tag-text">THERE IT IS.</span>
    </div>

    <div class="scroll-cue">
      <div class="scroll-line"></div>
      <span class="scroll-word">Scroll</span>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap');

  :root {
    --cream: #EFE8DA;
    --ink:   #1A1815;
    --gold:  #DCA145;
    --muted: #4A453E;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  .hero-wrap {
    width: 100%;
    padding: 0;
    background: #ffffff;
  }

  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    max-height: 920px;
    overflow: hidden;
    border-radius: 6px;
    background: var(--ink);
    font-family: 'Jost', sans-serif;
  }

  .bg-layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center center;
  }

  .bg-full  { opacity: 1; }
  .bg-empty { opacity: 0; }

  .edge-blur-left,
  .edge-blur-right {
    position: absolute;
    top: 0; bottom: 0;
    width: 5px;
    z-index: 1;
    pointer-events: none;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .edge-blur-left  { left: 0; }
  .edge-blur-right { right: 0; }

  .edge-fade {
    display: none;
  }

  /* ── STRONGER overlay: soft, high-end, bright sunny exposure overlay ── */
  .bg-overlay {
    position: absolute;
    inset: 0;
    background: 
      /* Soft left vignette to naturally lift the white text from the beige bg */
      linear-gradient(
        to right,
        rgba(18,15,12,0.18) 0%,
        rgba(18,15,12,0.22) 20%,
        rgba(18,15,12,0.15) 36%,
        rgba(18,15,12,0.05) 54%,
        transparent 68%
      ),
      /* Thin top vignette for navbar legibility without darkening the scene */
      linear-gradient(
        to bottom,
        rgba(18,15,12,0.05) 0%,
        transparent 12%
      );
    z-index: 3;
  }

  /* ── Content block ── */
  .content {
    position: absolute;
    z-index: 4;
    left: 6%;
    top: 50%;
    transform: translateY(-50%);
    max-width: 440px;
    padding: 8px 0;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.25s forwards;
  }

  .eyebrow-line {
    width: 32px;
    height: 1px;
    background: var(--gold);
    flex-shrink: 0;
  }

  .eyebrow-text {
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .headline {
    font-family: 'Playfair Display', serif;
    line-height: 1.08;
    letter-spacing: -0.01em;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.4s forwards;
  }

  .headline .line1 {
    font-size: clamp(32px, 3.8vw, 52px);
    font-weight: 400;
    display: block;
    color: var(--cream);
    text-shadow: 0 2px 10px rgba(18,15,12,0.2);
    letter-spacing: -0.02em;
  }

  .headline .line2 {
    font-size: clamp(32px, 3.8vw, 52px);
    font-weight: 300;
    font-style: italic;
    display: block;
    color: var(--gold);
    text-shadow: 0 2px 10px rgba(18,15,12,0.15);
    letter-spacing: -0.01em;
    margin-top: 4px;
  }

  .sub {
    margin-top: 20px;
    font-size: clamp(13px, 1.1vw, 15px);
    line-height: 1.65;
    color: rgba(239,232,218,0.9);
    font-weight: 300;
    max-width: 380px;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.55s forwards;
    text-shadow: 0 1px 6px rgba(18,15,12,0.15);
  }

  .cta-row {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 22px;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.7s forwards;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--ink);
    border: 1px solid var(--gold);
    border-radius: 2px;
    padding: 14px 28px;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-primary:hover {
    background: transparent;
    color: var(--cream);
    border-color: var(--cream);
  }

  .btn-ghost {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cream);
    background: transparent;
    border: 1px solid rgba(239, 232, 218, 0.4);
    border-radius: 2px;
    padding: 14px 28px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-ghost:hover {
    background: rgba(239, 232, 218, 0.08);
    border-color: var(--cream);
  }

  .tag {
    position: absolute;
    bottom: 32px;
    left: 6%;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 9px;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .tag.visible { opacity: 1; }

  .tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 1.8s ease-in-out infinite;
  }
  .presence-tag .tag-dot { animation-delay: 0.3s; }

  .tag-text {
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(239, 232, 218, 0.8);
    font-weight: 500;
  }

  .scroll-cue {
    position: absolute;
    bottom: 32px;
    right: 5%;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    animation: fadeIn 1s ease 1.5s forwards;
  }

  .scroll-word {
    font-size: 8px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(239,232,218,0.4);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 38px;
    background: rgba(239,232,218,0.2);
    position: relative;
    overflow: hidden;
  }

  .scroll-line::after {
    content: '';
    position: absolute;
    top: -100%; left: 0;
    width: 100%; height: 100%;
    background: var(--gold);
    animation: scrollDrop 2s ease-in-out 1.7s infinite;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }
  @keyframes scrollDrop {
    0%   { top: -100%; }
    100% { top: 200%; }
  }
</style>

<script>
  const bgFull      = document.getElementById('bgFull')      as HTMLElement;
  const bgEmpty     = document.getElementById('bgEmpty')     as HTMLElement;
  const absenceTag  = document.getElementById('absenceTag')  as HTMLElement;
  const presenceTag = document.getElementById('presenceTag') as HTMLElement;

  const VANISH  = 'cubic-bezier(0.7, 0, 0.84, 0)';
  const EASE_IN = 'cubic-bezier(0.16, 1, 0.3, 1)';

  function tr(el: HTMLElement, ms: number, easing: string) {
    el.style.transition = `opacity ${ms}ms ${easing}`;
  }

  tr(bgFull, 0, VANISH);
  tr(bgEmpty, 0, VANISH);
  bgFull.style.opacity  = '1';
  bgEmpty.style.opacity = '0';

  setTimeout(() => {
    tr(bgFull,  700, VANISH);
    tr(bgEmpty, 700, EASE_IN);
    bgFull.style.opacity  = '0';
    bgEmpty.style.opacity = '1';
    absenceTag.classList.add('visible');
  }, 3000);

  setTimeout(() => {
    absenceTag.classList.remove('visible');
    tr(bgFull,  700, VANISH);
    tr(bgEmpty, 700, VANISH);
    bgFull.style.opacity  = '1';
    bgEmpty.style.opacity = '0';
  }, 9000);

  setTimeout(() => {
    presenceTag.classList.add('visible');
  }, 9800);
</script>