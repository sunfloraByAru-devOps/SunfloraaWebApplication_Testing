---
import SUN_CLOSEUP from '../assets/sun_on_desk_closeup.png';
import STARS from '../assets/stars.png';
import SUNMOON from '../assets/sun_and_moon.jpg';
---

<section data-testid="packaging" class="py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 grid grid-cols-12 gap-10 items-center">

    <div class="col-span-12 lg:col-span-6">
      <p class="fade-up uppercase tracking-[0.28em] text-xs text-[#C8862C] mb-5">The unboxing</p>
      <h2 class="fade-up font-serif-display text-5xl md:text-6xl lg:text-7xl tracking-tighter leading-[1.05] text-[#1A1815]">
        A small <em>ritual</em>, before it's yours.
      </h2>
      <ul class="fade-up mt-10 space-y-5 text-[15px] md:text-[17px] leading-[1.7] text-[#4A453E]">
        <li class="flex gap-4">
          <svg class="w-5 h-5 text-[#C8862C] mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          Kraft paper folded by hand, sealed with our sun stamp.
        </li>
        <li class="flex gap-4">
          <svg class="w-5 h-5 text-[#C8862C] mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          A handwritten card with your piece's name and birthdate.
        </li>
        <li class="flex gap-4">
          <svg class="w-5 h-5 text-[#C8862C] mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.88 5.76a1 1 0 0 0 .95.69h6.05l-4.9 3.56a1 1 0 0 0-.36 1.12L17.5 20l-4.9-3.56a1 1 0 0 0-1.18 0L6.5 20l1.88-5.87a1 1 0 0 0-.36-1.12L3.12 9.45h6.05a1 1 0 0 0 .95-.69L12 3z"/></svg>
          Dried marigold petals, twine, and a free yarn keepsake.
        </li>
        <li class="flex gap-4">
          <svg class="w-5 h-5 text-[#C8862C] mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#C8862C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          A care guide, so your piece ages like a love letter.
        </li>
      </ul>
    </div>

    <div class="col-span-12 lg:col-span-6 grid grid-cols-2 gap-4 fade-up">
      <img src={SUN_CLOSEUP.src} alt="Crochet sun" class="aspect-square object-cover col-span-2" />
      <img src={STARS.src} alt="Crochet stars" class="aspect-[4/5] object-cover" />
      <img src={SUNMOON.src} alt="Sun and moon set" class="aspect-[4/5] object-cover" />
    </div>
  </div>
</section>