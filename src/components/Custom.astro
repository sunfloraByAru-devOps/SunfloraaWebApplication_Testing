<script>
  // Char counter
  const textarea = document.getElementById('tell-us') as HTMLTextAreaElement | null;
  const counter  = document.getElementById('char-count');
  if (textarea && counter) {
    textarea.addEventListener('input', () => {
      counter!.textContent = `${textarea.value.length}/1000`;
    });
  }

  // Size card toggle
  document.querySelectorAll<HTMLLabelElement>('.size-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.size-card').forEach(c => c.classList.remove('size-card--active'));
      card.classList.add('size-card--active');
    });
  });

  // Upload drag & drop
  const uploadZone = document.querySelector<HTMLLabelElement>('.upload-zone');
  if (uploadZone) {
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.style.borderColor = 'var(--col-gold)'; });
    uploadZone.addEventListener('dragleave', () => { uploadZone.style.borderColor = ''; });
    uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.style.borderColor = ''; });
  }
</script>